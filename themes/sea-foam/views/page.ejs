<%- include('partials/header') %>

<% if (themeConfig.show_page_sidebar && page.show_sidebar) { %>
<div class="layout-grid">
    <main class="post-list">
<% } %>

        <% if (themeConfig.cover_in_title_bg && page.cover_image && page.show_cover_in_post) { %>
        <article class="page-detail card page-background-cover" style="background-image: url('<%= page.cover_image %>');">
            <div class="page-cover-overlay">
                <h1 class="page-title" style="color: #ffffff; text-shadow: 0 2px 4px rgba(0,0,0,0.5); border-bottom: 2px solid rgba(255,255,255,0.2); padding-bottom: 15px; margin-bottom: 15px;"><%= page.title %></h1>
                <div class="post-meta" style="color: rgba(255,255,255,0.9); text-shadow: 0 1px 2px rgba(0,0,0,0.5); justify-content: center; margin-bottom: 20px;">
                    <span>👤 <%= site.computed_author_name %></span>
                    <% if (page.show_date) { %>
                    <span>📅 <%= new Date(page.created_at).toLocaleDateString() %></span>
                    <% } %>
                </div>
                <div class="page-content" style="color: rgba(255, 255, 255, 0.95); text-shadow: 0 1px 2px rgba(0,0,0,0.4); margin-top: 25px;">
                    <%- page.htmlContent %>
                </div>
            </div>
        </article>
        <% } else { %>
        <article class="page-detail card">
            <h1 class="page-title"><%= page.title %></h1>
            <div class="post-meta" style="justify-content: center; margin-bottom: 30px;">
                <span>👤 <%= site.computed_author_name %></span>
                <% if (page.show_date) { %>
                <span>📅 <%= new Date(page.created_at).toLocaleDateString() %></span>
                <% } %>
            </div>
            
            <% if (page.cover_image && page.show_cover_in_post) { %>
            <div class="page-cover" style="margin: 20px 0; text-align: center;">
                <img src="<%= page.cover_image %>" alt="<%= page.title %>" class="post-cover-img">
            </div>
            <% } %>

            <div class="page-content">
                <%- page.htmlContent %>
            </div>
        </article>
        <% } %>

        <% if (page.allow_comments) { %>
        <%
        function escapeHTML(str) {
            if (!str) return '';
            return String(str).replace(/[&<>'"]/g, tag => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                "'": '&#39;',
                '"': '&quot;'
            }[tag] || tag));
        }
        function renderCommentList(commentNodes) {
            if (!commentNodes || commentNodes.length === 0) return '';
            let html = '<ul class="comment-list" style="list-style: none; padding-left: 0; display: flex; flex-direction: column; gap: 20px; margin-top: 15px;">';
            commentNodes.forEach(comment => {
                html += `
                <li class="comment-item" id="comment-${comment.id}" style="border-bottom: 1px dashed var(--border-color); padding-bottom: 15px;">
                    <div class="comment-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; flex-wrap: wrap; gap: 5px;">
                        <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                            <strong style="color: var(--primary); font-size: 0.95rem;"><i class="ri-user-line"></i> ${escapeHTML(comment.author_name)}</strong>
                            ${comment.author_url ? `<a href="${escapeHTML(comment.author_url)}" target="_blank" rel="nofollow" style="font-size: 0.8rem; color: var(--text-muted); text-decoration: underline;"><i class="ri-global-line"></i> 网站</a>` : ''}
                            <span style="color: var(--text-muted); font-size: 0.8rem;"><i class="ri-calendar-line"></i> ${new Date(comment.created_at).toLocaleString()}</span>
                        </div>
                        <a href="#comment-form-title" onclick="appReplyComment(${comment.id}, '${escapeHTML(comment.author_name)}')" style="font-size: 0.85rem; color: var(--primary); text-decoration: none; font-weight: 600;"><i class="ri-chat-3-line"></i> 回复</a>
                    </div>
                    <div class="comment-body" style="font-size: 0.95rem; color: var(--text-main); line-height: 1.6; white-space: pre-wrap; word-break: break-all;">${escapeHTML(comment.content)}</div>
                `;
                if (comment.children && comment.children.length > 0) {
                    html += `<div class="comment-children" style="margin-left: 20px; padding-left: 15px; border-left: 2px solid var(--border-color); margin-top: 15px;">`;
                    html += renderCommentList(comment.children);
                    html += `</div>`;
                }
                html += `</li>`;
            });
            html += '</ul>';
            return html;
        }
        %>

        <div class="comments-section card" style="margin-top: 30px; padding: 25px;">
            <h3 style="margin-bottom: 20px; font-size: 1.3rem; border-bottom: 2px solid var(--primary); padding-bottom: 8px; display: inline-block;"><i class="ri-chat-3-line"></i> 评论交流 (<%= (function countComments(list) { let count = 0; list.forEach(c => { count += 1 + countComments(c.children || []); }); return count; })(comments) %>)</h3>

            <!-- Comment List -->
            <% if (comments.length === 0) { %>
                <p style="color: var(--text-muted); text-align: center; padding: 20px 0; font-size: 0.95rem;">暂无评论，快来发表第一条评论吧！</p>
            <% } else { %>
                <%- renderCommentList(comments) %>
            <% } %>

            <!-- Comment Form -->
            <div class="comment-form-container" style="margin-top: 40px; padding-top: 25px; border-top: 1px solid var(--border-color);">
                <h4 id="comment-form-title" style="margin-bottom: 20px; font-size: 1.1rem; display: flex; align-items: center; gap: 10px;">发表评论 
                    <span id="reply-target-text" style="font-size: 0.85rem; color: var(--primary); font-weight: normal;"></span> 
                    <button id="reply-cancel-btn" onclick="appCancelReply()" style="display:none; background: none; border: 1px solid var(--border-color); padding: 2px 8px; border-radius: 4px; cursor: pointer; color: var(--text-muted); font-size: 0.75rem;">取消回复</button>
                </h4>
                
                <form action="/comment" method="POST" class="custom-comment-form" style="display: flex; flex-direction: column; gap: 20px;">
                    <input type="hidden" name="page_id" value="<%= page.id %>">
                    <input type="hidden" name="parent_id" id="comment-parent-id" value="">
                    
                    <input type="text" name="honeypot" style="display:none" tabindex="-1" autocomplete="off">

                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                        <div class="form-input-group">
                            <input type="text" name="author_name" required placeholder="称呼 (必填)" style="width: 100%; padding: 12px 15px; border: 2px solid rgba(255,255,255,0.3); border-radius: 12px; outline: none; background: rgba(255,255,255,0.4); backdrop-filter: blur(4px); color: var(--text-main); font-size: 0.95rem; transition: all 0.3s;" onfocus="this.style.borderColor='var(--primary)'; this.style.background='rgba(255,255,255,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.3)'; this.style.background='rgba(255,255,255,0.4)'">
                        </div>
                        <div class="form-input-group">
                            <input type="email" name="author_email" placeholder="邮箱 (选填)" style="width: 100%; padding: 12px 15px; border: 2px solid rgba(255,255,255,0.3); border-radius: 12px; outline: none; background: rgba(255,255,255,0.4); backdrop-filter: blur(4px); color: var(--text-main); font-size: 0.95rem; transition: all 0.3s;" onfocus="this.style.borderColor='var(--primary)'; this.style.background='rgba(255,255,255,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.3)'; this.style.background='rgba(255,255,255,0.4)'">
                        </div>
                        <div class="form-input-group">
                            <input type="url" name="author_url" placeholder="网站 http:// (选填)" style="width: 100%; padding: 12px 15px; border: 2px solid rgba(255,255,255,0.3); border-radius: 12px; outline: none; background: rgba(255,255,255,0.4); backdrop-filter: blur(4px); color: var(--text-main); font-size: 0.95rem; transition: all 0.3s;" onfocus="this.style.borderColor='var(--primary)'; this.style.background='rgba(255,255,255,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.3)'; this.style.background='rgba(255,255,255,0.4)'">
                        </div>
                    </div>

                    <div class="form-input-group">
                        <textarea name="content" required placeholder="在这里写下您的精彩评论..." style="width: 100%; height: 140px; padding: 15px; border: 2px solid rgba(255,255,255,0.3); border-radius: 12px; resize: vertical; outline: none; line-height: 1.6; background: rgba(255,255,255,0.4); backdrop-filter: blur(4px); color: var(--text-main); font-size: 1rem; transition: all 0.3s;" onfocus="this.style.borderColor='var(--primary)'; this.style.background='rgba(255,255,255,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.3)'; this.style.background='rgba(255,255,255,0.4)'"></textarea>
                    </div>

                    <div style="text-align: right;">
                        <button type="submit" style="padding: 12px 35px; border-radius: 25px; background: var(--primary); color: white; border: none; cursor: pointer; font-weight: bold; font-size: 1rem; box-shadow: 0 4px 10px rgba(14, 165, 233, 0.3); transition: transform 0.2s, box-shadow 0.3s;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 15px rgba(14, 165, 233, 0.4)'" onmouseout="this.style.transform='none'; this.style.boxShadow='0 4px 10px rgba(14, 165, 233, 0.3)'"><i class="ri-send-plane-fill"></i> 发布评论</button>
                    </div>
                </form>
            </div>
        </div>

        <script>
        function appReplyComment(commentId, authorName) {
            document.getElementById('comment-parent-id').value = commentId;
            document.getElementById('reply-target-text').innerText = '正在回复 ' + authorName;
            document.getElementById('reply-cancel-btn').style.display = 'inline-block';
        }
        function appCancelReply() {
            document.getElementById('comment-parent-id').value = '';
            document.getElementById('reply-target-text').innerText = '';
            document.getElementById('reply-cancel-btn').style.display = 'none';
        }
        </script>
        <% } %>

<% if (themeConfig.show_page_sidebar && page.show_sidebar) { %>
    </main>
    <%- include('partials/sidebar') %>
</div>
<% } %>

<%- include('partials/footer') %>
