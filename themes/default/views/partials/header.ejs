<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - <%= site.site_title %></title>
    <meta name="description" content="<%= site.site_description %>">
    <% if (site.site_keywords) { %><meta name="keywords" content="<%= site.site_keywords %>"><% } %>

    <style id="theme-custom-vars">
        <%- customCssVars %>
    </style>
    <link rel="stylesheet" href="/theme-assets/<%= theme %>/css/remixicon.css">
    <link rel="stylesheet" href="/theme-assets/<%= theme %>/css/style.css">
</head>
<body>
    <header class="site-header">
        <div class="header-inner">
            <a href="/" class="site-title"><%= site.site_title %></a>
            <button class="menu-toggle" id="menu-toggle" aria-label="Menu">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
            <nav class="site-nav" id="site-nav">
                <a href="/">首页</a>
                <% navPages.forEach(p => { %>
                    <a href="/page/<%= p.slug %>"><%= p.title %></a>
                <% }) %>
            </nav>
        </div>
    </header>
    <div class="container main-wrapper">
