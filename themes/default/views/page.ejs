<%- include('partials/header') %>

<% if (page.show_sidebar) { %>
<div class="layout-grid">
    <main class="post-list">
<% } %>

        <article class="page-detail card">
            <h1 class="page-title"><%= page.title %></h1>
            <div class="post-meta" style="justify-content: center; margin-bottom: 30px;">
                <span><i class="ri-user-line"></i> <%= site.computed_author_name %></span>
                <% if (page.show_date) { %>
                <span><i class="ri-calendar-line"></i> <%= new Date(page.created_at).toLocaleDateString() %></span>
                <% } %>
            </div>
            
            <% if (page.cover_image && page.show_cover_in_post) { %>
            <div class="page-cover" style="margin: 20px 0; text-align: center;">
                <img src="<%= page.cover_image %>" alt="<%= page.title %>" class="post-cover-img">
            </div>
            <% } %>

            <div class="page-content">
                <%- page.htmlContent %>
            </div>
        </article>

        <% if (page.allow_comments) { %>
        <%
        function escapeHTML(str) {
            if (!str) return '';
            return String(str).replace(/[&<>'"]/g, tag => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                "'": '&#39;',
                '"': '&quot;'
            }[tag] || tag));
        }
        function renderCommentList(commentNodes) {
            if (!commentNodes || commentNodes.length === 0) return '';
            let html = '<ul class="comment-list" style="list-style: none; padding-left: 0; display: flex; flex-direction: column; gap: 20px; margin-top: 15px;">';
            commentNodes.forEach(comment => {
                html += `
                <li class="comment-item" id="comment-${comment.id}" style="border-bottom: 1px dashed var(--border-color); padding-bottom: 15px;">
                    <div class="comment-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; flex-wrap: wrap; gap: 5px;">
                        <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                            <strong style="color: var(--primary); font-size: 0.95rem;"><i class="ri-user-line"></i> ${escapeHTML(comment.author_name)}</strong>
                            ${comment.author_url ? `<a href="${escapeHTML(comment.author_url)}" target="_blank" rel="nofollow" style="font-size: 0.8rem; color: var(--text-muted); text-decoration: underline;"><i class="ri-global-line"></i> 网站</a>` : ''}
                            <span style="color: var(--text-muted); font-size: 0.8rem;"><i class="ri-calendar-line"></i> ${new Date(comment.created_at).toLocaleString()}</span>
                        </div>
                        <a href="#comment-form-title" onclick="appReplyComment(${comment.id}, '${escapeHTML(comment.author_name)}')" style="font-size: 0.85rem; color: var(--primary); text-decoration: none; font-weight: 600;"><i class="ri-chat-3-line"></i> 回复</a>
                    </div>
                    <div class="comment-body" style="font-size: 0.95rem; color: var(--text-main); line-height: 1.6; white-space: pre-wrap; word-break: break-all;">${escapeHTML(comment.content)}</div>
                `;
                if (comment.children && comment.children.length > 0) {
                    html += `<div class="comment-children" style="margin-left: 20px; padding-left: 15px; border-left: 2px solid var(--border-color); margin-top: 15px;">`;
                    html += renderCommentList(comment.children);
                    html += `</div>`;
                }
                html += `</li>`;
            });
            html += '</ul>';
            return html;
        }
        %>

        <div class="comments-section card" style="margin-top: 30px; padding: 25px;">
            <h3 style="margin-bottom: 20px; font-size: 1.3rem; border-bottom: 2px solid var(--primary); padding-bottom: 8px; display: inline-block;"><i class="ri-chat-3-line"></i> 评论交流 (<%= (function countComments(list) { let count = 0; list.forEach(c => { count += 1 + countComments(c.children || []); }); return count; })(comments) %>)</h3>

            <!-- Comment List -->
            <% if (comments.length === 0) { %>
                <p style="color: var(--text-muted); text-align: center; padding: 20px 0; font-size: 0.95rem;">暂无评论，快来发表第一条评论吧！</p>
            <% } else { %>
                <%- renderCommentList(comments) %>
            <% } %>

            <!-- Comment Form -->
            <div class="comment-form-container" style="margin-top: 40px; padding-top: 25px; border-top: 1px solid var(--border-color);">
                <h4 id="comment-form-title" style="margin-bottom: 20px; font-size: 1.1rem; display: flex; align-items: center; gap: 10px;">发表评论 
                    <span id="reply-target-text" style="font-size: 0.85rem; color: var(--primary); font-weight: normal;"></span> 
                    <button id="reply-cancel-btn" onclick="appCancelReply()" style="display:none; background: none; border: 1px solid var(--border-color); padding: 2px 8px; border-radius: 4px; cursor: pointer; color: var(--text-muted); font-size: 0.75rem;">取消回复</button>
                </h4>
                
                <form action="/comment" method="POST" style="display: flex; flex-direction: column; gap: 15px;">
                    <input type="hidden" name="page_id" value="<%= page.id %>">
                    <input type="hidden" name="parent_id" id="comment-parent-id" value="">
                    
                    <!-- Honeypot anti-spam -->
                    <input type="text" name="honeypot" style="display:none" tabindex="-1" autocomplete="off">

                    <div style="display: grid; grid-template-columns: 1fr; gap: 15px;">
                        <div style="display: flex; flex-direction: column; gap: 5px;">
                            <label style="font-size: 0.9rem; color: var(--text-muted);">称呼 <span style="color:red;">*</span></label>
                            <input type="text" name="author_name" required style="width: 100%; padding: 8px 12px; border: 1px solid var(--border-color); border-radius: var(--radius); outline: none; background: transparent; color: inherit;" placeholder="您的昵称">
                        </div>
                        <div style="display: flex; flex-direction: column; gap: 5px;">
                            <label style="font-size: 0.9rem; color: var(--text-muted);">电子邮箱</label>
                            <input type="email" name="author_email" style="width: 100%; padding: 8px 12px; border: 1px solid var(--border-color); border-radius: var(--radius); outline: none; background: transparent; color: inherit;" placeholder="用于展示头像 (可选)">
                        </div>
                        <div style="display: flex; flex-direction: column; gap: 5px;">
                            <label style="font-size: 0.9rem; color: var(--text-muted);">个人网站</label>
                            <input type="url" name="author_url" style="width: 100%; padding: 8px 12px; border: 1px solid var(--border-color); border-radius: var(--radius); outline: none; background: transparent; color: inherit;" placeholder="以http://或https://开头 (可选)">
                        </div>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 5px;">
                        <label style="font-size: 0.9rem; color: var(--text-muted);">内容 <span style="color:red;">*</span></label>
                        <textarea name="content" required style="width: 100%; height: 120px; padding: 10px 12px; border: 1px solid var(--border-color); border-radius: var(--radius); resize: vertical; outline: none; line-height: 1.6; background: transparent; color: inherit;" placeholder="在这里写下您的评论内容..."></textarea>
                    </div>

                    <div>
                        <button type="submit" style="padding: 8px 25px; border-radius: var(--radius); background: var(--primary); color: white; border: none; cursor: pointer; font-weight: 600; transition: background 0.2s;">提交评论</button>
                    </div>
                </form>
            </div>
        </div>

        <script>
        function appReplyComment(commentId, authorName) {
            document.getElementById('comment-parent-id').value = commentId;
            document.getElementById('reply-target-text').innerText = '正在回复 ' + authorName;
            document.getElementById('reply-cancel-btn').style.display = 'inline-block';
        }
        function appCancelReply() {
            document.getElementById('comment-parent-id').value = '';
            document.getElementById('reply-target-text').innerText = '';
            document.getElementById('reply-cancel-btn').style.display = 'none';
        }
        </script>
        <% } %>

<% if (page.show_sidebar) { %>
    </main>
    <%- include('partials/sidebar') %>
</div>
<% } %>

<%- include('partials/footer') %>
