<%- include('partials/header') %>

<%
const isLeftLayout = themeConfig.post_cover_mode === 'left_cover_sidebar_left';
%>

<div class="layout-grid <%= isLeftLayout ? 'layout-left-sidebar' : '' %>">
    
    <% if (isLeftLayout) { %>
        <%- include('partials/sidebar', { show_left_cover: true }) %>
    <% } %>

    <main class="post-list">
        <article class="post-detail card">
            
            <% if (themeConfig.post_cover_mode === 'above_title' && post.cover_image && post.show_cover_in_post) { %>
            <div class="post-cover-above-title" style="margin-bottom: 20px; text-align: center;">
                <img src="<%= post.cover_image %>" alt="<%= post.title %>" class="post-cover-img" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: var(--radius);">
            </div>
            <% } %>

            <h1 class="post-title"><%= post.title %></h1>
            <div class="post-meta">
                <span><i class="ri-user-line"></i> <%= site.computed_author_name %></span>
                <span><i class="ri-calendar-line"></i> <%= new Date(post.created_at).toLocaleDateString() %></span>
                <% if (post.category_name) { %>
                    <span><i class="ri-folder-line"></i> <a href="/category/<%= post.category_slug %>" style="color: inherit; text-decoration: underline;"><%= post.category_name %></a></span>
                <% } %>
                <span><i class="ri-eye-line"></i> <%= post.views %> 次阅读</span>
            </div>

            <% if ((themeConfig.post_cover_mode === 'default' || !themeConfig.post_cover_mode) && post.cover_image && post.show_cover_in_post) { %>
            <div class="post-cover" style="margin: 20px 0; text-align: center;">
                <img src="<%= post.cover_image %>" alt="<%= post.title %>" class="post-cover-img">
            </div>
            <% } %>
            
            <div class="post-content">
                <%- post.htmlContent %>
            </div>

            <% if (post.tags && post.tags.length > 0) { %>
            <div class="post-tags" style="margin-top: 30px; padding-top: 15px; border-top: 1px dashed var(--border-color); display: flex; flex-wrap: wrap; align-items: center; gap: 4px;">
                <span style="font-weight: 600; margin-right: 8px; color: var(--text-muted);"><i class="ri-price-tag-3-line"></i> 标签:</span>
                <% post.tags.forEach(tag => { %>
                    <a href="/tag/<%= encodeURIComponent(tag) %>" class="default-tag"><%= tag %></a>
                <% }) %>
            </div>
            <% } %>

            <!-- Prev/Next Navigation -->
            <div class="post-navigation" style="margin-top: 30px; display: flex; justify-content: space-between; gap: 20px; border-top: 1px dashed var(--border-color); padding-top: 20px; flex-wrap: wrap;">
                <div class="nav-prev" style="flex: 1; min-width: 200px;">
                    <% if (prevPost) { %>
                        <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 5px;">← 上一篇</div>
                        <a href="/post/<%= prevPost.slug %>" style="font-weight: 600;"><%= prevPost.title %></a>
                    <% } else { %>
                        <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 5px;">← 没有了</div>
                        <span style="color: var(--text-muted); font-size: 0.95rem;">已经是第一篇了</span>
                    <% } %>
                </div>
                <div class="nav-next" style="flex: 1; min-width: 200px; text-align: right;">
                    <% if (nextPost) { %>
                        <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 5px;">下一篇 →</div>
                        <a href="/post/<%= nextPost.slug %>" style="font-weight: 600;"><%= nextPost.title %></a>
                    <% } else { %>
                        <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 5px;">没有了 →</div>
                        <span style="color: var(--text-muted); font-size: 0.95rem;">已经是最后一篇了</span>
                    <% } %>
                </div>
            </div>
        </article>

        <%
        function escapeHTML(str) {
            if (!str) return '';
            return String(str).replace(/[&<>'"]/g, tag => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                "'": '&#39;',
                '"': '&quot;'
            }[tag] || tag));
        }
        function renderCommentList(commentNodes) {
            if (!commentNodes || commentNodes.length === 0) return '';
            let html = '<ul class="comment-list" style="list-style: none; padding-left: 0; display: flex; flex-direction: column; gap: 20px; margin-top: 15px;">';
            commentNodes.forEach(comment => {
                html += `
                <li class="comment-item" id="comment-${comment.id}" style="border-bottom: 1px dashed var(--border-color); padding-bottom: 15px;">
                    <div class="comment-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; flex-wrap: wrap; gap: 5px;">
                        <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                            <strong style="color: var(--primary); font-size: 0.95rem;"><i class="ri-user-line"></i> ${escapeHTML(comment.author_name)}</strong>
                            ${comment.author_url ? `<a href="${escapeHTML(comment.author_url)}" target="_blank" rel="nofollow" style="font-size: 0.8rem; color: var(--text-muted); text-decoration: underline;"><i class="ri-global-line"></i> 网站</a>` : ''}
                            <span style="color: var(--text-muted); font-size: 0.8rem;"><i class="ri-calendar-line"></i> ${new Date(comment.created_at).toLocaleString()}</span>
                        </div>
                        <a href="#comment-form-title" onclick="appReplyComment(${comment.id}, '${escapeHTML(comment.author_name)}')" style="font-size: 0.85rem; color: var(--primary); text-decoration: none; font-weight: 600;"><i class="ri-chat-3-line"></i> 回复</a>
                    </div>
                    <div class="comment-body" style="font-size: 0.95rem; color: var(--text-main); line-height: 1.6; white-space: pre-wrap; word-break: break-all;">${escapeHTML(comment.content)}</div>
                `;
                if (comment.children && comment.children.length > 0) {
                    html += `<div class="comment-children" style="margin-left: 20px; padding-left: 15px; border-left: 2px solid var(--border-color); margin-top: 15px;">`;
                    html += renderCommentList(comment.children);
                    html += `</div>`;
                }
                html += `</li>`;
            });
            html += '</ul>';
            return html;
        }
        %>

        <div class="comments-section card" style="margin-top: 30px; padding: 25px;">
            <h3 style="margin-bottom: 20px; font-size: 1.3rem; border-bottom: 2px solid var(--primary); padding-bottom: 8px; display: inline-block;"><i class="ri-chat-3-line"></i> 评论交流 (<%= (function countComments(list) { let count = 0; list.forEach(c => { count += 1 + countComments(c.children || []); }); return count; })(comments) %>)</h3>

            <!-- Comment List -->
            <% if (comments.length === 0) { %>
                <p style="color: var(--text-muted); text-align: center; padding: 20px 0; font-size: 0.95rem;">暂无评论，快来发表第一条评论吧！</p>
            <% } else { %>
                <%- renderCommentList(comments) %>
            <% } %>

            <!-- Comment Form -->
            <div class="comment-form-container" style="margin-top: 40px; padding-top: 25px; border-top: 1px solid var(--border-color);">
                <h4 id="comment-form-title" style="margin-bottom: 20px; font-size: 1.1rem; display: flex; align-items: center; gap: 10px;">发表评论 
                    <span id="reply-target-text" style="font-size: 0.85rem; color: var(--primary); font-weight: normal;"></span> 
                    <button id="reply-cancel-btn" onclick="appCancelReply()" style="display:none; background: none; border: 1px solid var(--border-color); padding: 2px 8px; border-radius: 4px; cursor: pointer; color: var(--text-muted); font-size: 0.75rem;">取消回复</button>
                </h4>
                
                <form action="/comment" method="POST" class="custom-comment-form" style="display: flex; flex-direction: column; gap: 20px;">
                    <input type="hidden" name="post_id" value="<%= post.id %>">
                    <input type="hidden" name="parent_id" id="comment-parent-id" value="">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    
                    <!-- Honeypot anti-spam -->
                    <input type="text" name="honeypot" style="display:none" tabindex="-1" autocomplete="off">

                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                        <div class="form-input-group">
                            <input type="text" name="author_name" required placeholder="称呼 (必填)" style="width: 100%; padding: 12px 15px; border: 2px solid var(--border-color); border-radius: 0; outline: none; background: var(--bg-alt, #f9f9f9); color: var(--text-main); font-size: 0.95rem; transition: border-color 0.3s;" onfocus="this.style.borderColor='var(--primary)'" onblur="this.style.borderColor='var(--border-color)'">
                        </div>
                        <div class="form-input-group">
                            <input type="email" name="author_email" placeholder="邮箱 (选填)" style="width: 100%; padding: 12px 15px; border: 2px solid var(--border-color); border-radius: 0; outline: none; background: var(--bg-alt, #f9f9f9); color: var(--text-main); font-size: 0.95rem; transition: border-color 0.3s;" onfocus="this.style.borderColor='var(--primary)'" onblur="this.style.borderColor='var(--border-color)'">
                        </div>
                        <div class="form-input-group">
                            <input type="url" name="author_url" placeholder="网站 http:// (选填)" style="width: 100%; padding: 12px 15px; border: 2px solid var(--border-color); border-radius: 0; outline: none; background: var(--bg-alt, #f9f9f9); color: var(--text-main); font-size: 0.95rem; transition: border-color 0.3s;" onfocus="this.style.borderColor='var(--primary)'" onblur="this.style.borderColor='var(--border-color)'">
                        </div>
                    </div>

                    <div class="form-input-group">
                        <textarea name="content" required placeholder="在这里写下您的评论内容..." style="width: 100%; height: 140px; padding: 15px; border: 2px solid var(--border-color); border-radius: 0; resize: vertical; outline: none; line-height: 1.6; background: var(--bg-alt, #f9f9f9); color: var(--text-main); font-size: 1rem; transition: border-color 0.3s;" onfocus="this.style.borderColor='var(--primary)'" onblur="this.style.borderColor='var(--border-color)'"></textarea>
                    </div>

                    <div style="text-align: right;">
                        <button type="submit" style="padding: 10px 30px; border-radius: 0; background: var(--primary); color: white; border: none; cursor: pointer; font-weight: bold; font-size: 1rem; transition: background 0.3s;">发布评论</button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <% if (!isLeftLayout) { %>
        <%- include('partials/sidebar', { show_left_cover: false }) %>
    <% } %>
</div>

<script>
function appReplyComment(commentId, authorName) {
    document.getElementById('comment-parent-id').value = commentId;
    document.getElementById('reply-target-text').innerText = '正在回复 ' + authorName;
    document.getElementById('reply-cancel-btn').style.display = 'inline-block';
}
function appCancelReply() {
    document.getElementById('comment-parent-id').value = '';
    document.getElementById('reply-target-text').innerText = '';
    document.getElementById('reply-cancel-btn').style.display = 'none';
}
</script>

<%- include('partials/footer') %>
